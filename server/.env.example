# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=verify-full

# Redis
REDIS_URL=redis://default:password@host:6379/1

# Data Warehouse (для Cube.js)
DATABASE_URL_WAREHOUSE=postgresql://user:password@host:5432/data_warehouse?sslmode=verify-full

# Analytics Database (для Cube.js)
DATABASE_URL_ANALYTICS=postgresql://user:password@host:5432/analytics_db?sslmode=verify-full

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
