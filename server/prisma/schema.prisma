generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TestMigration {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  note      String?
}
