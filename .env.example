# ===========================================
# ZeroApp Environment Variables
# Скопируйте в .env и заполните значения
# ===========================================

# ================================
# Server (NestJS)
# ================================
NODE_ENV=production
PORT=3000

# Database (PostgreSQL) - основная БД
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=verify-full

# Redis
REDIS_URL=redis://default:password@host:6379/1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ================================
# Cube.js Analytics
# ================================
# БД аналитики (отдельная от основной)
CUBEJS_DB_HOST=host
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=analytics_db
CUBEJS_DB_USER=analytics_user
CUBEJS_DB_PASS=password

# Cube.js API Secret (генерируйте случайную строку)
CUBEJS_API_SECRET=your-cubejs-api-secret-change-in-production

# ================================
# Client (Vite)
# ================================
VITE_API_URL=/api
