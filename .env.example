# ===========================================
# ZeroReports Environment Variables
# Copy this file to .env and fill in real values
# ===========================================

# Server (NestJS)
# Use "development" locally, "production" in deployed env
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# Replace CHANGE_ME with a strong password
DATABASE_URL=postgresql://zeroreports:CHANGE_ME_IN_PRODUCTION@postgres:5432/zeroreports
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Client (Vite)
# Development: use Vite dev proxy (http://localhost:3000)
# Production (nginx): use /api so nginx proxies to server
VITE_API_URL=/api

# MUI X License Key (optional — for MUI X Pro components)
VITE_MUI_LICENSE_KEY=your-key-here
